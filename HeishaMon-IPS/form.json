{
    "elements": [
        {
            "type": "ValidationTextBox",
            "name": "MQTTTopic",
            "caption": "MQTT base topic"
        },
        {
            "type": "CheckBox",
            "name": "DebugUnknownTopics",
            "caption": "Debug: unknown topics"
        },
        {
            "type": "Label",
            "caption": "Variables are created automatically as soon as HeishaMon publishes the corresponding topics."
        },
        {
            "type": "List",
            "name": "VariableList",
            "caption": "Datapoints",
            "rowCount": 15,
            "add": false,
            "delete": false,
            "changeOrder": true,
            "loadValuesFromConfiguration": false,
            "columns": [
                {
                    "caption": "Active",
                    "name": "Selected",
                    "width": "80px",
                    "add": true,
                    "edit": {
                        "type": "CheckBox"
                    }
                },
                {
                    "caption": "Name",
                    "name": "Caption",
                    "width": "auto",
                    "add": ""
                },
                {
                    "caption": "Group",
                    "name": "Group",
                    "width": "170px",
                    "add": ""
                },
                {
                    "caption": "Topic",
                    "name": "Topic",
                    "width": "320px",
                    "add": "",
                    "save": true
                },
                {
                    "caption": "Received",
                    "name": "Received",
                    "width": "110px",
                    "add": ""
                }
            ],
            "values": []
        },
        {
            "type": "Label",
            "caption": "Deactivated datapoints are hidden - object ID and archive data remain. New topics are only created while activated. Reorder rows by drag & drop - variables and links follow the order."
        },
        {
            "type": "ExpansionPanel",
            "caption": "Link structure",
            "items": [
                {
                    "type": "Label",
                    "caption": "Creates a grouped category tree (Operation, Heating, DHW, ...) with links to all active datapoints at the selected location. Links of deactivated datapoints are removed automatically."
                },
                {
                    "type": "CheckBox",
                    "name": "CreateLinks",
                    "caption": "Create link structure"
                },
                {
                    "type": "SelectCategory",
                    "name": "LinksLocation",
                    "caption": "Target category"
                }
            ]
        },
        {
            "type": "ExpansionPanel",
            "caption": "External energy meter (COP / performance factor)",
            "items": [
                {
                    "type": "Label",
                    "caption": "If an external energy meter (e.g. Shelly 3EM) measures the heat pump supply line, select its variables here. The module then calculates the measured COP and the daily performance factor from the meter readings."
                },
                {
                    "type": "SelectVariable",
                    "name": "PowerVariable",
                    "caption": "Energy meter: active power of the heat pump (W)"
                },
                {
                    "type": "SelectVariable",
                    "name": "EnergyVariable",
                    "caption": "Energy meter: energy counter of the heat pump (kWh)"
                },
                {
                    "type": "NumberSpinner",
                    "name": "COPMinPower",
                    "caption": "Minimum power for COP calculation",
                    "suffix": " W"
                }
            ]
        }
    ],
    "actions": [
        {
            "type": "Button",
            "caption": "Reset order and selection",
            "confirm": "Really reset the datapoint list to its default order and selection?",
            "onClick": "HEISHA_ResetVariableList($_IPS['TARGET']);"
        },
        {
            "type": "TestCenter"
        }
    ],
    "status": []
}
